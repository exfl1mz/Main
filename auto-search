local function fetchRobux(userId: string): number?
    local res = Request({
        Url = `https://economy.roblox.com/v1/users/{userId}/currency`,
        Method = "GET",
        Headers = {
            ["Cookie"] = `.ROBLOSECURITY={config.ROBLOSECURITY}`
        }
    })
    if res.StatusCode == 200 then
        return env.HttpService:JSONDecode(res.Body).robux
    end
    return nil
end

local function fetchCSRF(): string?
    local res = Request({
        Url = "https://auth.roblox.com/v2/logout",
        Method = "POST",
        Headers = {
            ["Cookie"] = `.ROBLOSECURITY={config.ROBLOSECURITY}`,
            ["Content-Type"] = "application/json"
        }
    })
    if res and res.Headers and res.Headers["x-csrf-token"] then
        getgenv().config.CSRF = res.Headers["x-csrf-token"]
        return getgenv().config.CSRF
    end
    return nil
end

