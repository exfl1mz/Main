Notify.OnClientEvent:Connect(function(...)
    if not config.Rolimons.AutoSearch then return end

    local args = {...}
    local AssetId = args[1]
    local data = args[2]
    
    if not AssetId or not data then return end
    
    local location_type = data.location_type
    local detection_time = data.detection_time
    local price = data.price
    local notifyName = data.name

    local canBuy = (location_type == 1 or location_type == 5 or location_type == 7)
    local isPaid = (price and price > 1)

    if canBuy and price == 0 then
        local success, itemData = pcall(function()
            return _payload(AssetId)
        end)
        
        if not success or not itemData then
            print("Failed to get item data")
            return
        end
        
        task.spawn(function()
            local buyResultRaw = _BUY(AssetId)

            if buyResultRaw and buyResultRaw.purchased then
                local Quantity = itemData.metadata.Quantity or 1
                local Remaining = itemData.metadata.Remaining or 0
                
                local Serial, RemainingStock = getSerial(AssetId, Quantity, Remaining)
                
                if Serial then
                    Notification:Notify(
                        {Title = notifyName, Description = `New Item Purchased: \nSerial: #{Serial}\nStock Left: {RemainingStock}`},
                        {OutlineColor = Color3.fromRGB(0, 0, 255), Time = 120, Type = "image"},
                        {Image = `rbxthumb://type=Asset&id={AssetId}&w=420&h=420`, ImageColor = Color3.fromRGB(255, 255, 255)}
                    )

                    if WebhookUrl then
                        SendWebhookUrl(WebhookUrl, false, true, true, Serial, RemainingStock, AssetId)
                    end
                end
            else
                local errorTable = {
                    ["NotForSale"] = "Item offsale",
                    ["QuantityExhausted"] = "Already sold out",
                    ["QuantityLimitExceeded"] = "Reached Quantity Limit",
                    ["MissingPurchaseAuthToken"] = "PurchaseAuthToken not found",
                    ["InvalidSaleLocation"] = "Invalid Sale Location",
                    ["GameVerificationError"] = "You not in game?",
                    ["PriceMismatch"] = "Price changed",
                    ["InsufficientFunds"] = "Not enough Robux",
                    ["AlreadyOwned"] = "Already owned",
                    ["Unauthorized"] = "Auth failed",
                    ["TooManyRequests"] = "Rate limited",
                    ["Flooded: purchase requests exceeds limit"] = "Hold on! you reached purchase limit",
                    ["ItemNotFound"] = "Item not found?",
                    ["InvalidParameter"] = "Invalid parameters",
                    ["PurchaseNotAllowed"] = "Purchase blocked (PIN/age)",
                    ["Unavailable"] = "Item unavailable"
                }

                local rawError = (buyResultRaw and buyResultRaw.errorMessage) or "Unknown error"
                local errorMsg = errorTable[rawError] or rawError

                Notification:Notify(
                    {Title = notifyName, Description = errorMsg},
                    {OutlineColor = Color3.fromRGB(0, 0, 255), Time = 60, Type = "image"},
                    {Image = `rbxthumb://type=Asset&id={AssetId}&w=420&h=420`, ImageColor = Color3.fromRGB(255, 255, 255)}
                )

                if WebhookFails then
                    SendWebhookFails(WebhookFails, errorMsg, AssetId)
                end
            end
        end)
    end

    local websiteId, ingameId, paidId = nil, nil, nil

    if canBuy and not isPaid then
        websiteId = AssetId
    elseif isPaid then
        paidId = AssetId
    else
        ingameId = AssetId
    end

    getgenv().lastIds = getgenv().lastIds or {website = cache.website, ingame = cache.free, paid = cache.paid}
    if websiteId then getgenv().lastIds.website = websiteId end
    if ingameId then getgenv().lastIds.ingame = ingameId end
    if paidId then getgenv().lastIds.paid = paidId end

    local names = {}
    for key, id in pairs(getgenv().lastIds) do
        if (key == "website" and websiteId) or (key == "ingame" and ingameId) or (key == "paid" and paidId) then
            names[key] = notifyName
        end
    end

    pcall(function()
        Window:Update({
            [1] = {text = names.website, image = `rbxthumb://type=Asset&id={getgenv().lastIds.website}&w=420&h=420`},
            [2] = {text = names.ingame, image = `rbxthumb://type=Asset&id={getgenv().lastIds.ingame}&w=420&h=420`},
            [3] = {text = names.paid, image = `rbxthumb://type=Asset&id={getgenv().lastIds.paid}&w=420&h=420`}
        })
    end)

    pcall(function()
        if Window.sectionsList and #Window.sectionsList == 3 then
            Window.sectionsList[1].obj:UpdateInfo({
                name = names.website,
                image = `rbxthumb://type=Asset&id={getgenv().lastIds.website}&w=420&h=420`,
                template = "Last Web UGC"
            })
            Window.sectionsList[2].obj:UpdateInfo({
                name = names.ingame,
                image = `rbxthumb://type=Asset&id={getgenv().lastIds.ingame}&w=420&h=420`,
                template = "Last Ingame UGC"
