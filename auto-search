local function fetchAccountInfo(): (string?, string?)
    local res = Request({
        Url = "https://users.roblox.com/v1/users/authenticated",
        Method = "GET",
        Headers = {
            ["Cookie"] = `.ROBLOSECURITY={config.ROBLOSECURITY}`
        }
    })
    if res.StatusCode == 200 then
        local decoded = env.HttpService:JSONDecode(res.Body)
        return tostring(decoded.id), decoded.name
    end
    return nil, "Unknown?"
end

