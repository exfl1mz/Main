local function _BUY(assetId: number): table?
    local success, productInfo = pcall(function()
        return env.MarketplaceService:GetProductInfoAsync(assetId)
    end)
    if not success or not productInfo then
        return nil
    end

    local payload = {
        collectibleItemId = tostring(productInfo.CollectibleItemId),
        collectibleProductId = tostring(productInfo.CollectibleProductId),
        expectedCurrency = 1,
        expectedPrice = productInfo.PriceInRobux or 0,
        expectedPurchaserId = tostring(purchasedId),
        expectedPurchaserType = "User",
        expectedSellerId = tonumber(productInfo.Creator.Id),
        expectedSellerType = tostring(productInfo.Creator.CreatorType),
        idempotencyKey = env.HttpService:GenerateGUID(false),
    }

    local csrf = getgenv().config.CSRF
    if not csrf then
        csrf = fetchCSRF()
        if not csrf then
            return nil
        end
    end

    local url = `https://apis.roblox.com/marketplace-sales/v1/item/{productInfo.CollectibleItemId}/purchase-item`
    local headers = {
        ["Content-Type"] = "application/json;charset=UTF-8",
        ["Cookie"] = `.ROBLOSECURITY={config.ROBLOSECURITY}`,
        ["X-CSRF-TOKEN"] = csrf,
        ["Referer"] = "https://www.roblox.com/",
        ["Origin"] = "https://www.roblox.com",
        ["User-Agent"] = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36",
        ["Accept"] = "*/*",
        ["Accept-Language"] = "ru,en-US;q=0.9,en;q=0.8,nl;q=0.7"
    }

    local response = Request({
        Url = url,
        Method = "POST",
        Headers = headers,
        Body = env.HttpService:JSONEncode(payload)
    })

    if response.purchased then
        return env.HttpService:JSONDecode(response.Body)
    else
        if response.StatusCode == 403 and response.Body:find("XSRF") then
            fetchCSRF()
            headers["X-CSRF-TOKEN"] = getgenv().config.CSRF
            response = Request({
                Url = url,
                Method = "POST",
                Headers = headers,
                Body = env.HttpService:JSONEncode(payload)
            })
            if response.purchased and response.StatusCode == 200 then
                return env.HttpService:JSONDecode(response.Body)
            end
        end
        local decodeSuccess, decoded = pcall(function()
            return env.HttpService:JSONDecode(response.Body)
        end)
        return decodeSuccess and decoded or nil
    end
end

