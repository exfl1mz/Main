local function _payload(assetId: number): {metadata: table}?
    local itemInfo = env.MarketplaceService:GetProductInfo(assetId)

    local metadata = {
        AssetId = itemInfo.AssetId,
        Name = itemInfo.Name,
        Description = itemInfo.Description,
        AssetTypeId = itemInfo.AssetTypeId,
        ProductType = itemInfo.ProductType,
        IsForSale = itemInfo.IsForSale,
        IsLimited = itemInfo.IsLimited,
        IsLimited2 = itemInfo.CollectiblesItemDetails.IsLimited or false,
        IsLimitedUnique = itemInfo.IsLimitedUnique,
        Remaining = itemInfo.Remaining or nil,
        Quantity = itemInfo.CollectiblesItemDetails.TotalQuantity or nil,
        Sales = itemInfo.Sales,
        Created = itemInfo.Created,
        Updated = itemInfo.Updated,
        MinimumMembershipLevel = itemInfo.MinimumMembershipLevel,
        ContentRatingTypeId = itemInfo.ContentRatingTypeId,
        IconImageAssetId = itemInfo.IconImageAssetId,
        TargetId = itemInfo.TargetId,
        CollectibleItemId = itemInfo.CollectibleItemId,
        CollectibleProductId = itemInfo.CollectibleProductId,
        Creator = {
            Id = itemInfo.Creator.CreatorTargetID,
            Name = itemInfo.Creator.Name,
            CreatorType = itemInfo.Creator.CreatorType,
            CreatorTargetId = itemInfo.Creator.CreatorTargetId,
            HasVerifiedBadge = itemInfo.Creator.HasVerifiedBadge
        }
    }

    return {
        metadata = metadata
    }
end

local function GetImage(id: number): string?
    local success, response = pcall(function()
        return env.HttpService:JSONDecode(Request({
            Method = "GET",
            Url = `https://thumbnails.roblox.com/v1/assets?assetIds={id}&size=420x420&format=Png&isCircular=false`
        }).Body)
    end)
    
    if success and response and response.data and response.data[1] and response.data[1].imageUrl then
        return response.data[1].imageUrl
    else
        return nil
    end
end

local pagination: string? = nil

local function getSerial(itemID: number, Quantity: number, Remaining: number): (string, string)
    local ItemInfo = env.MarketplaceService:GetProductInfo(itemID)
    local res = Request({
        Url = `https://inventory.roblox.com/v2/users/{purchasedId}/inventory/{ItemInfo.AssetTypeId}?limit=100&sortOrder=Desc&cursor={pagination or ""}`,
        Method = "GET",
        Headers = {
            ["Cookie"] = `.ROBLOSECURITY={config.ROBLOSECURITY}`
        }
    })
    if res.StatusCode ~= 200 then 
        return tostring(tonumber(Quantity) - tonumber(Remaining) + 1), tostring(tonumber(Remaining) - 1)
    end
    local decoded = env.HttpService:JSONDecode(res.Body)

    for i, v in pairs(decoded.data) do
        if v["assetId"] == itemID then
            pagination = nil
            local serial = v["serialNumber"]
            return serial, tostring(tonumber(Quantity) - tonumber(serial))
        end
    end

    pagination = decoded.nextPageCursor 
    if not pagination then 
        return tostring(tonumber(Quantity) - tonumber(Remaining) + 1), tostring(tonumber(Remaining) - 1)
    end

    return getSerial(itemID, Quantity, Remaining)
end

